{"file":"_category_-CJZgVaaL.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;mBACOA,eAAAC,WAAA,EAAA,OAAM,0FAAyF,GAAA,MAAA,CAAA,oFAK1F,OAAK,QAAA,QAAQ,OAAM,CAAA,CAAA,kBAAM,OAAK,QAAA,QAAQ,KAAK,saAK1CC,eAAA,QAAA,QAAQ,KAAK;;;;;;;;;;;;;;;;;;;;;;;;;ACgD1B,UAAM,QAAQ;AAkBd,UAAM,MAAM,MAAM,QAAQ,CAAC,QAAQ;AACjC,UAAI,KAAK;AACP,QAAA,SAAS,KAAK,MAAM,WAAW;AAAA,MACjC,OAAO;AACL,QAAA,SAAS,KAAK,MAAM,WAAW;AAAA,MACjC;AAAA,IACF,CAAC;;+BAlFC,CAmDWC,WAAA;AAjDI,YAAA,QAAA,UAAU,QAAA,SAAO;;AASfA,iBAAAC,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,kEAAA,GAAiE,MAAA,OAAA,CAAA;;AAKpDC,wBAAA,QAAA,QAAQ,QAAM,CAA3B,KAAK,QAAG;0IACbC,cAAA,OAAK,GAAG,kBAAG,OAAK,QAAA,QAAQ,KAAK;;yUAQmEL,eAAA,QAAA,QAAQ,KAAK,qHAE9GA,eAAA,QAAA,QAAQ,WAAW;AAMb,cAAA,QAAA,QAAQ,YAAY,QAAA,QAAQ,aAAQ,OAAA;AAEeC,mBAAA,kNAAAD,eAAA,QAAA,QAAQ,QAAQ,CAAA,YAAA;AAAA;;;AAEnE,cAAA,QAAA,QAAQ,UAAQ;AAEmCC,mBAAA,iNAAAD,eAAA,QAAA,QAAQ,QAAQ,CAAA,YAAA;AAAA;;;AAEnE,cAAA,QAAA,QAAQ,MAAI;AAEuCC,mBAAA,6MAAAD,eAAA,QAAA,QAAQ,IAAI,CAAA,YAAA;AAAA;;;;;;;;;;;;;;;;;;;;;;ACQxF,UAAM,QAAQ,SAAA;AACd,UAAM,gBAAgB,MAAM,OAAO;AAEnC,UAAM,EAAE,sBAAA,IAA0B,YAAA;AAElC,UAAM,mBAAmB,SAAS,MAAM;AACtC,aAAO,sBAAsB,aAAa;AAAA,IAC5C,CAAC;AAED,UAAM,wBAAwB,SAAS,MAAM;AAC3C,UAAI,CAAC,iBAAiB,kBAAkB,MAAO,QAAO;AACtD,aAAO,cAAc,QAAQ,KAAK,GAAG;AAAA,IACvC,CAAC;AAGD,UAAM,cAAc,IAAI,KAAK;AAC7B,UAAM,kBAAkB,IAAI,IAAI;AAEhC,UAAM,kBAAkB,CAAC,YAAY;AACnC,sBAAgB,QAAQ;AACxB,kBAAY,QAAQ;AAAA,IACtB;AAEA,UAAM,mBAAmB,MAAM;AAC7B,kBAAY,QAAQ;AACpB,iBAAW,MAAM;AACf,wBAAgB,QAAQ;AAAA,MAC1B,GAAG,GAAG;AAAA,IACR;;;AA/EO,YAAA,OAAAF,eAAAC,WAAA,EAAA,OAAM,oHAAgH,MAAA,CAAA,CAAA,+GAAA;;QAI7G,IAAG;AAAA,QAAY,OAAM;AAAA,MAAA;yBAA/B,CAGW,GAAAE,QAAAK,UAAA,aAAA;;AAFML,mBAAAC,mBAAAC,MAAA,aAAA,GAAA,EAAA,OAAM,+EAA2E,MAAAG,UAAA,QAAA,CAAA;;;;cAAhGC,YAAmGJ,MAAA,aAAA,GAAA,EAApF,OAAM,6EAA2E;AAAA,8BAAG,oBAErG;AAAA,YAAA;AAAA;;;;4IAGK,sBAAA,KAAqB,CAAA,OAAA;AAEjB,UAAA,iBAAA,MAAiB,WAAM,GAAA;;;kHAI3BH,eAAA,iBAAA,MAAiB,MAAM,YAAcA,eAAA,iBAAA,MAAiB,WAAM,IAAA,MAAA,EAAA;;;AAOtD,UAAA,iBAAA,MAAiB,SAAM,GAAA;;AAEZI,sBAAA,iBAAA,QAAX,YAAO;;YACb,KAAK,QAAQ;AAAA,YACb;AAAA,YACA,aAAY;AAAA,UAAA;;;;;;;;QAOhB,WAAS,YAAA;AAAA,QACT,SAAS,gBAAA;AAAA,QACT,SAAO;AAAA,MAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrInterpolate","_push","_ssrRenderComponent","_unref","_ssrRenderList","_ssrRenderAttr","_parent","_createVNode"],"sources":["../../../../components/ProjectCard.vue","../../../../components/ProjectModal.vue","../../../../pages/projects/[category].vue"],"sourcesContent":["<template>\n  <div class=\"relative group cursor-pointer overflow-hidden break-inside-avoid mb-6 rounded-sm w-full\" @click=\"emit('openModal', project)\">\n    <!-- Container preserving the aspect ratio naturally through the image, break-inside-avoid prevents cutting in masonry -->\n    \n    <div class=\"w-full h-full relative overflow-hidden bg-muted\">\n      <!-- Main Image -->\n      <img :src=\"project.images[0]\" :alt=\"project.title\" class=\"w-full object-cover transition-all duration-[1s] ease-out group-hover:scale-105\" loading=\"lazy\" />\n      \n      <!-- Overlay -->\n      <div class=\"absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out flex flex-col justify-end p-6 md:p-8\">\n        <h3 class=\"text-white text-lg md:text-xl font-bold tracking-tight uppercase translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-out\">\n          {{ project.title }}\n        </h3>\n        <p class=\"text-white/70 text-xs tracking-widest uppercase mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-700 delay-100\">\n          Click to View\n        </p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nconst props = defineProps({\n  project: {\n    type: Object,\n    required: true\n  }\n})\n\nconst emit = defineEmits(['openModal'])\n</script>\n","<template>\n  <Teleport to=\"body\">\n    <Transition name=\"modal\">\n      <div v-if=\"isOpen && project\" class=\"fixed inset-0 z-50 flex items-center justify-center pointer-events-auto\">\n        <!-- Backdrop -->\n        <div class=\"absolute inset-0 bg-black/80 backdrop-blur-sm\" @click=\"close\"></div>\n        \n        <!-- Modal Content Container -->\n        <div class=\"relative w-[95vw] h-[95vh] md:w-[90vw] md:h-[90vh] bg-surface rounded-sm flex flex-col shadow-2xl overflow-hidden scale-100 modal-card border border-border\">\n          \n          <!-- Close Button -->\n          <button @click=\"close\" class=\"absolute top-6 right-6 z-10 w-12 h-12 bg-white/50 backdrop-blur-md rounded-full flex items-center justify-center hover:bg-black hover:text-white transition-colors duration-300 text-black shadow-sm group\">\n            <XIcon class=\"w-6 h-6 transition-transform duration-300 group-hover:rotate-90\" />\n          </button>\n\n          <!-- Top: Image Gallery (Horizontal Scroll) -->\n          <div class=\"w-full h-1/2 md:h-2/3 bg-muted overflow-x-auto flex snap-x snap-mandatory hide-scrollbar\">\n            <div v-for=\"(img, idx) in project.images\" :key=\"idx\" class=\"h-full min-w-full md:min-w-[80%] lg:min-w-[70%] snap-center flex-shrink-0 relative\">\n              <img :src=\"img\" :alt=\"project.title\" class=\"w-full h-full object-cover transition-all duration-1000\" loading=\"lazy\" />\n            </div>\n          </div>\n\n          <!-- Bottom: Details -->\n          <div class=\"w-full h-1/2 md:h-1/3 p-8 md:p-12 overflow-y-auto bg-background flex flex-col lg:flex-row justify-between gap-12\">\n            <!-- Title & Desc -->\n            <div class=\"lg:w-2/3\">\n              <h2 class=\"text-3xl md:text-4xl lg:text-5xl font-bold tracking-tighter uppercase text-accent mb-6\">{{ project.title }}</h2>\n              <p class=\"text-sm md:text-base text-text-secondary leading-relaxed tracking-wide max-w-2xl\">\n                {{ project.description }}\n              </p>\n            </div>\n            \n            <!-- Metadata -->\n            <div class=\"lg:w-1/3 flex flex-col gap-6 pt-2 lg:pt-0 lg:border-l border-border lg:pl-12\">\n              <div v-if=\"project.roomSize && project.roomSize !== 'N/A'\">\n                <p class=\"text-[10px] font-bold tracking-widest uppercase text-text-secondary mb-1\">Room Size</p>\n                <p class=\"text-sm font-medium tracking-wide text-accent\">{{ project.roomSize }}</p>\n              </div>\n              <div v-if=\"project.location\">\n                <p class=\"text-[10px] font-bold tracking-widest uppercase text-text-secondary mb-1\">Location</p>\n                <p class=\"text-sm font-medium tracking-wide text-accent\">{{ project.location }}</p>\n              </div>\n              <div v-if=\"project.date\">\n                <p class=\"text-[10px] font-bold tracking-widest uppercase text-text-secondary mb-1\">Date</p>\n                <p class=\"text-sm font-medium tracking-wide text-accent\">{{ project.date }}</p>\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </Transition>\n  </Teleport>\n</template>\n\n<script setup>\nimport { onMounted, onUnmounted, watch } from 'vue'\nimport { XIcon } from 'lucide-vue-next'\n\nconst props = defineProps({\n  isOpen: {\n    type: Boolean,\n    required: true\n  },\n  project: {\n    type: Object,\n    default: null\n  }\n})\n\nconst emit = defineEmits(['close'])\n\nconst close = () => {\n  emit('close')\n}\n\n// Lock scroll when open\nwatch(() => props.isOpen, (val) => {\n  if (val) {\n    document.body.style.overflow = 'hidden'\n  } else {\n    document.body.style.overflow = ''\n  }\n})\n\nonUnmounted(() => {\n  document.body.style.overflow = ''\n})\n</script>\n\n<style scoped>\n.hide-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.hide-scrollbar {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n\n/* Vue Transition Classes */\n.modal-enter-active,\n.modal-leave-active {\n  transition: opacity 0.5s ease;\n}\n.modal-enter-from,\n.modal-leave-to {\n  opacity: 0;\n}\n\n.modal-enter-active .modal-card {\n  transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);\n}\n.modal-leave-active .modal-card {\n  transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);\n}\n\n.modal-enter-from .modal-card,\n.modal-leave-to .modal-card {\n  transform: scale(0.95);\n}\n</style>\n","<template>\n  <div class=\"relative w-full bg-background font-sans text-text-primary selection:bg-black selection:text-white min-h-screen\">\n    \n    <!-- HEADER -->\n    <section class=\"max-w-[1440px] mx-auto px-6 md:px-8 pt-32 pb-16 fade-in-up\">\n      <NuxtLink to=\"/projects\" class=\"inline-flex items-center text-[10px] font-bold tracking-widest uppercase text-text-secondary hover:text-text-primary transition-colors mb-12 group\">\n        <ArrowLeftIcon class=\"w-3 h-3 mr-2 transition-transform duration-300 group-hover:-translate-x-1\" />\n        Back to Projects\n      </NuxtLink>\n      \n      <h1 class=\"text-4xl md:text-5xl lg:text-7xl font-bold tracking-tighter uppercase text-accent\">\n        {{ formattedCategoryName }}\n      </h1>\n      <p v-if=\"filteredProjects.length === 0\" class=\"mt-8 text-sm text-text-secondary tracking-widest uppercase\">\n        No projects found.\n      </p>\n      <p v-else class=\"mt-4 text-xs md:text-sm text-text-secondary tracking-widest uppercase\">\n        {{ filteredProjects.length }} Project{{ filteredProjects.length !== 1 ? 's' : '' }}\n      </p>\n    </section>\n\n    <!-- MASONRY GRID -->\n    <!-- CSS Columns provide a lightweight masonry layout. `columns-1 md:columns-2 lg:columns-3` coupled with `break-inside-avoid` in the children items. -->\n    <section class=\"max-w-[1440px] mx-auto px-6 md:px-8 pb-32\">\n      <div v-if=\"filteredProjects.length > 0\" class=\"columns-1 md:columns-2 lg:columns-3 gap-6 w-full fade-in-up delay-100\">\n        <ProjectCard \n          v-for=\"project in filteredProjects\" \n          :key=\"project.id\" \n          :project=\"project\" \n          @open-modal=\"handleOpenModal\"\n        />\n      </div>\n    </section>\n\n    <!-- PROJECT MODAL -->\n    <ProjectModal \n      :is-open=\"isModalOpen\" \n      :project=\"selectedProject\" \n      @close=\"handleCloseModal\" \n    />\n\n  </div>\n</template>\n\n<script setup>\nimport { computed, ref, onMounted } from 'vue'\nimport { useRoute } from 'vue-router'\nimport { ArrowLeftIcon } from 'lucide-vue-next'\nimport { useProjects } from '~/composables/useProjects'\nimport ProjectCard from '~/components/ProjectCard.vue'\nimport ProjectModal from '~/components/ProjectModal.vue'\n\nconst route = useRoute()\nconst categoryParam = route.params.category\n\nconst { getProjectsByCategory } = useProjects()\n\nconst filteredProjects = computed(() => {\n  return getProjectsByCategory(categoryParam)\n})\n\nconst formattedCategoryName = computed(() => {\n  if (!categoryParam || categoryParam === 'all') return 'All Projects'\n  return categoryParam.replace('-', ' ')\n})\n\n// Modal State\nconst isModalOpen = ref(false)\nconst selectedProject = ref(null)\n\nconst handleOpenModal = (project) => {\n  selectedProject.value = project\n  isModalOpen.value = true\n}\n\nconst handleCloseModal = () => {\n  isModalOpen.value = false\n  setTimeout(() => {\n    selectedProject.value = null\n  }, 500) // Clear after modal out transition\n}\n\nonMounted(() => {\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        entry.target.classList.add('visible')\n      } else {\n        entry.target.classList.remove('visible')\n      }\n    })\n  }, { threshold: 0.1, rootMargin: \"0px 0px -50px 0px\" })\n\n  document.querySelectorAll('.fade-in-up').forEach((el) => {\n    observer.observe(el)\n  })\n})\n</script>\n\n<style scoped>\n.fade-in-up {\n  opacity: 0;\n  transform: translateY(40px);\n  transition: opacity 0.8s cubic-bezier(0.19, 1, 0.22, 1), transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);\n}\n.fade-in-up.visible {\n  opacity: 1;\n  transform: translate(0, 0);\n}\n.delay-100 {\n  transition-delay: 100ms;\n}\n</style>\n"],"version":3}